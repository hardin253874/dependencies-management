# Dependencies Management Agent — environment variables
# Copy to .env and fill in. Never commit .env (gitignored).

# --- LLM provider credentials ---
# At least one of these is required, matching the active provider in library/_config.json.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Logging ---
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- Dev / Test toggles ---
# When true, the LLM client returns fixture responses keyed by prompt-hash.
MOCK_LLM=false

# --- Token budgets (optional; defaults baked in) ---
# View [E] File Review
TOKEN_BUDGET_FILE_REVIEW_IN=30000
TOKEN_BUDGET_FILE_REVIEW_OUT=4000
# View [D] Update Report
TOKEN_BUDGET_UPDATE_REPORT_IN=10000
TOKEN_BUDGET_UPDATE_REPORT_OUT=6000
# View [D-Deep] Deep Report
TOKEN_BUDGET_DEEP_REPORT_IN=100000
TOKEN_BUDGET_DEEP_REPORT_OUT=8000

# --- Server bind (do not change; documented for clarity) ---
# Server always binds 127.0.0.1; no override allowed.
